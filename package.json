{
  "name": "broker-chat-vscode",
  "displayName": "Broker Chat",
  "description": "A local VS Code broker panel for Codex and Claude Code.",
  "version": "0.2.0",
  "publisher": "local",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pengqiyu123/broker-chat-vscode.git"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:broker.openChat",
    "onCommand:broker.newSession",
    "onCommand:broker.stopActiveResponse",
    "onCommand:broker.showLogs",
    "onCommand:broker.probeFocus",
    "onView:brokerChatSidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "brokerChatSidebarContainer",
          "title": "Broker Chat",
          "icon": "media/broker-icon.svg"
        }
      ]
    },
    "views": {
      "brokerChatSidebarContainer": [
        {
          "id": "brokerChatSidebar",
          "type": "webview",
          "name": "Broker Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "broker.openChat",
        "title": "Open Broker Chat"
      },
      {
        "command": "broker.newSession",
        "title": "New Broker Session"
      },
      {
        "command": "broker.stopActiveResponse",
        "title": "Stop Active Response"
      },
      {
        "command": "broker.showLogs",
        "title": "Show Broker Chat Logs"
      },
      {
        "command": "broker.probeFocus",
        "title": "Probe Broker Focus"
      }
    ],
    "configuration": {
      "title": "Broker Chat",
      "properties": {
        "broker.codexPath": {
          "type": "string",
          "default": "codex",
          "description": "Executable path for Codex CLI."
        },
        "broker.claudePath": {
          "type": "string",
          "default": "claude",
          "description": "Executable path for Claude Code CLI."
        },
        "broker.zcodeDataDir": {
          "type": "string",
          "default": "",
          "description": "ZCode desktop data directory (the folder whose child .zcode/v2/config.json holds provider config). Leave empty to disable ZCode bridging."
        },
        "broker.zcodeExePath": {
          "type": "string",
          "default": "",
          "description": "ZCode.exe path. Auto-discovered from the running ZCode process and persisted. Cleared if it becomes invalid."
        },
        "broker.bridgePair": {
          "type": "object",
          "default": { "red": "claude", "blue": "codex" },
          "description": "Active bridge pair (red/blue agents). Persisted across restarts. null for an unselected slot."
        },
        "broker.defaultReturnMode": {
          "type": "string",
          "enum": [
            "compact",
            "full"
          ],
          "default": "compact",
          "description": "Default return payload mode used during auto debate."
        },
        "broker.defaultAutoDebateRounds": {
          "type": "number",
          "enum": [
            1,
            2,
            3
          ],
          "default": 1,
          "description": "Default number of auto debate rounds."
        },
        "broker.claudePermissionMode": {
          "type": "string",
          "enum": [
            "default",
            "plan",
            "acceptEdits",
            "auto",
            "bypassPermissions",
            "dontAsk"
          ],
          "default": "default",
          "description": "Permission mode forwarded to Claude headless runs."
        },
        "broker.claudeAllowedTools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Optional allowed tools forwarded to Claude as --allowedTools."
        },
        "broker.autoForwardEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic forwarding when Broker detects target keywords in official transcript user messages."
        },
        "broker.autoForwardKeywords": {
          "type": "object",
          "default": {
            "codex": [
              "给Codex命令",
              "给codex命令",
              "发送给codex",
              "发给codex",
              "转给codex",
              "转发给codex",
              "问codex",
              "给 Codex",
              "发送给 Codex",
              "发给 Codex",
              "转给 Codex",
              "转发给 Codex",
              "问 Codex"
            ],
            "claude": [
              "回复ClaudeCode",
              "回复claudecode",
              "给ClaudeCode命令",
              "给claudecode命令",
              "发送给claude",
              "发给claude",
              "转给claude",
              "转发给claude",
              "问claude",
              "给 Claude",
              "发送给 Claude",
              "发给 Claude",
              "转给 Claude",
              "转发给 Claude",
              "问 Claude"
            ]
          },
          "description": "Automatic forwarding keywords grouped by target agent."
        },
        "broker.directionalRolePrefixes": {
          "type": "object",
          "default": {
            "red": "身份：你是ClaudeCode，本项目专职产品经理，统筹多智能体开发项目，不编写代码，只拆解需求、输出开发指令、验收Codex开发成果、下发整改要求。\n协作关系：Codex为首席开发主管，带队多智能体团队编码落地，严格按你的指令开发。",
            "blue": "身份锁定：你是Codex，首席开发负责人，统领多智能体开发小组，负责全部代码实现。\n上级对接：ClaudeCode为本项目产品经理，只下发开发指令、验收成果、提出修改意见，你严格按照ClaudeCode的指令开发。"
          },
          "description": "Role-locking text for the red/blue bridge slots. red is prepended when forwarding into the red agent; blue when forwarding into the blue agent. Empty value preserves the plain bridge prompt."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test:bridge": "node scripts/test-bridge-prompt.js",
    "test:auto-forward": "node scripts/test-auto-forward.js",
    "test:powershell": "node scripts/test-powershell-scripts.js",
    "watch": "tsc -w -p ./",
    "package:vsix": "powershell -ExecutionPolicy Bypass -File .\\scripts\\package-vsix.ps1",
    "install:local": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install-local.ps1",
    "uninstall:local": "powershell -ExecutionPolicy Bypass -File .\\scripts\\uninstall-local.ps1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.98.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.8.3"
  }
}
