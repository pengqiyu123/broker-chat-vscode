{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "outDir": "../../dist/mcp",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "types": [
      "node"
    ],
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "skipLibCheck": true
  },
  "include": [
    "broker-mcp-server.ts"
  ]
}
